APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=e_com
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=null
# Set all three in production. The session holds the cart and the signed-in user
# id; without SESSION_SECURE_COOKIE the cookie is transmitted over plain HTTP.
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

CONTACT_MAIL_TO=

# Stripe. STRIPE_KEY is the PUBLISHABLE key (pk_...) and is rendered into the
# browser on the checkout page -- that is expected. STRIPE_SECRET (sk_...) is
# server-side only and must never reach a Blade template or client-side JS.
STRIPE_KEY=
STRIPE_SECRET=

# TinyMCE editor key (client-side, domain-locked at cloud.tiny.cloud)
TINYMCE_API_KEY=

# Client-side analytics identifiers. Public by design -- these ship to the
# browser on every request. Leave unset to fall back to config/services.php.
META_PIXEL_ID=
GOOGLE_ANALYTICS_ID=

# TikTok Events API (server-side)
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_API_ENDPOINT="https://business-api.tiktok.com/open_api/v1.3/event/track/"
TIKTOK_EVENTS_ENABLED=true
#TIKTOK_TEST_EVENT_CODE=
